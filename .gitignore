# Local scratch / backup artifacts — never deploy these.
# (Netlify's secret scanner fails the build if these reach the repo, since they
#  contain the Supabase publishable key in paths outside SECRETS_SCAN_OMIT_PATHS.)
files.zip
_redirects_riley.txt
riley-auth-patch.html
814-agent-prompts.js
node_modules/
.DS_Store

# Regenerable social-template render output (run brand/template-kit/make_*.py to
# rebuild). The kit SOURCE (grounds, engines, fonts, spec) IS committed; the
# ~120MB rendered library is not - it bloats history and is fully reproducible.
brand/template-kit/library/
brand/template-kit/__pycache__/

# Test-runner local state (written on every run by tests/*/runner.js - never source)
tests/**/.last-run.json
